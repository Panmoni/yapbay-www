---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Badge from "@components/ui/badge.astro";
import Link from "@components/ui/link.astro";
import { Picture } from "astro:assets";
import heroImage from "@assets/hero-screenshot.png";
---

<Layout footerMargin={false}>
  <!-- Hero -->
  <div class="py-16 md:py-24">
    <Container>
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-secondary-300 text-secondary-600 text-sm font-medium mb-6">
          <span class="w-2 h-2 rounded-full bg-secondary-500 animate-pulse"></span>
          MVP Live at app.yapbay.com
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-neutral-900 tracking-tight [text-wrap:balance]">
          Send money home<br class="hidden md:block" /> at a fraction of the cost.
        </h1>

        <p class="text-lg md:text-xl text-neutral-600 mt-6 max-w-xl mx-auto [text-wrap:pretty]">
          YapBay is a peer-to-peer remittances protocol. No bank accounts, no KYC, no custodian. Just fast, cheap transfers to where you need them most.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <Link size="lg" style="primary" href="https://app.yapbay.com" target="_blank" rel="noopener">Try the App</Link>
          <Link size="lg" style="outline" href="https://github.com/Panmoni/yapbay" target="_blank" rel="noopener">View on GitHub</Link>
        </div>
      </div>
    </Container>
  </div>

  <!-- Social Proof Strip -->
  <div class="border-y border-neutral-200 py-10">
    <Container>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-3xl font-bold text-primary-600">~$0</div>
          <p class="text-sm text-neutral-500 mt-1">Protocol fees</p>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary-600">24/7</div>
          <p class="text-sm text-neutral-500 mt-1">Always-on P2P matching</p>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary-600">0</div>
          <p class="text-sm text-neutral-500 mt-1">KYC required</p>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary-600">MIT</div>
          <p class="text-sm text-neutral-500 mt-1">Open source license</p>
        </div>
      </div>
    </Container>
  </div>

  <!-- The $900 Billion Problem -->
  <div class="py-16 bg-gradient-to-bl from-primary-900 to-primary-700 text-white">
    <Container>
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight [text-wrap:balance]">
          The $900 Billion Remittances Problem
        </h2>
        <p class="text-neutral-400 mt-3 text-lg">Sub-$200 remittances face the highest fees, disproportionately hurting the families that need every dollar most.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8 text-center">
        <div>
          <div class="text-4xl md:text-5xl font-bold text-primary-400">6.36%</div>
          <p class="text-neutral-400 text-sm mt-2">Global average cost to send $200 (World Bank, Q2 2025). More than double the 3% SDG target.</p>
        </div>
        <div>
          <div class="text-4xl md:text-5xl font-bold text-primary-400">8.78%</div>
          <p class="text-neutral-400 text-sm mt-2">Average cost to send $200 to Sub-Saharan Africa (World Bank, Q1 2025). The world's most expensive corridor.</p>
        </div>
        <div>
          <div class="text-4xl md:text-5xl font-bold text-primary-400">800M+</div>
          <p class="text-neutral-400 text-sm mt-2">People without official ID, locked out of formal financial systems. Another 2.8B lack digital ID.</p>
        </div>
      </div>
    </Container>
  </div>

  <!-- Three Steps. No Custody. -->
  <div class="py-20">
    <Container>
      <div class="max-w-2xl mx-auto text-center mb-12">
        <Badge color="primary">HOW IT WORKS</Badge>
        <h2 class="text-3xl md:text-4xl font-bold text-neutral-900 tracking-tight mt-4">
          Three steps. No custody.
        </h2>
        <p class="text-neutral-600 mt-3 [text-wrap:pretty]">P2P Remittances via Stablecoin Rails — chain two P2P trade offers into one fiat-in, fiat-out transaction.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-primary-100 text-primary-600 font-bold text-xl flex items-center justify-center mx-auto">1</div>
          <h3 class="font-semibold text-neutral-900 mt-4">Choose an offer</h3>
          <p class="text-sm text-neutral-600 mt-2">Browse P2P offers from traders in your corridor. Each offer shows the exchange rate and fees.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-primary-100 text-primary-600 font-bold text-xl flex items-center justify-center mx-auto">2</div>
          <h3 class="font-semibold text-neutral-900 mt-4">Deposit stablecoin</h3>
          <p class="text-sm text-neutral-600 mt-2">Send USDC to the smart contract escrow. Your funds are locked by code, not a company.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-primary-100 text-primary-600 font-bold text-xl flex items-center justify-center mx-auto">3</div>
          <h3 class="font-semibold text-neutral-900 mt-4">Recipient receives fiat</h3>
          <p class="text-sm text-neutral-600 mt-2">A second trader delivers local fiat to your recipient. Escrow releases your USDC atomically.</p>
        </div>
      </div>
    </Container>
  </div>

  <!-- What We Stand For -->
  <div class="py-20 bg-gradient-to-bl from-primary-900 to-primary-700 text-white">
    <Container>
      <div class="text-center mb-12">
        <Badge color="secondary">OUR VALUES</Badge>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight mt-4">
          What We Stand For
        </h2>
      </div>
      <div class="grid md:grid-cols-5 gap-6">
        <div class="bg-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl mb-3">🌍</div>
          <h3 class="font-bold text-lg">Financial Inclusion</h3>
          <p class="text-neutral-400 text-sm mt-2">Banking the unbanked — 2 billion people deserve access to global finance.</p>
        </div>
        <div class="bg-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl mb-3">💸</div>
          <h3 class="font-bold text-lg">Affordable Remittances</h3>
          <p class="text-neutral-400 text-sm mt-2">High fees on small transfers are a tax on the poor. We end that.</p>
        </div>
        <div class="bg-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl mb-3">🛡️</div>
          <h3 class="font-bold text-lg">Censorship Resistance</h3>
          <p class="text-neutral-400 text-sm mt-2">No one should be able to block your access to your own money.</p>
        </div>
        <div class="bg-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl mb-3">🔄</div>
          <h3 class="font-bold text-lg">Crisis Resilience</h3>
          <p class="text-neutral-400 text-sm mt-2">When TradFi fails, P2P networks keep flowing.</p>
        </div>
        <div class="bg-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl mb-3">⚡</div>
          <h3 class="font-bold text-lg">Economic Empowerment</h3>
          <p class="text-neutral-400 text-sm mt-2">Every human should be able to participate in the global economy.</p>
        </div>
      </div>
    </Container>
  </div>

  <!-- Built on Trustless Infrastructure -->
  <div class="py-16">
    <Container>
      <div class="max-w-2xl mx-auto text-center mb-10">
        <Badge color="primary">TRUST & SECURITY</Badge>
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-900 tracking-tight mt-4">
          Built on trustless infrastructure
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        <div class="bg-neutral-100 rounded-xl p-6 flex gap-4">
          <div class="shrink-0 w-10 h-10 rounded-lg bg-primary-100 flex items-center justify-center">
            <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-neutral-900">Smart contract escrow</h3>
            <p class="text-sm text-neutral-600 mt-1">Funds held in smart contracts. No middleman can access them.</p>
          </div>
        </div>

        <div class="bg-neutral-100 rounded-xl p-6 flex gap-4">
          <div class="shrink-0 w-10 h-10 rounded-lg bg-primary-100 flex items-center justify-center">
            <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-neutral-900">No identity verification</h3>
            <p class="text-sm text-neutral-600 mt-1">Protocol-level KYC-free. Your financial activity is your own business.</p>
          </div>
        </div>

        <div class="bg-neutral-100 rounded-xl p-6 flex gap-4">
          <div class="shrink-0 w-10 h-10 rounded-lg bg-primary-100 flex items-center justify-center">
            <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-neutral-900">Fully transparent</h3>
            <p class="text-sm text-neutral-600 mt-1">All code is MIT licensed and publicly auditable. No hidden logic.</p>
          </div>
        </div>

        <div class="bg-neutral-100 rounded-xl p-6 flex gap-4">
          <div class="shrink-0 w-10 h-10 rounded-lg bg-primary-100 flex items-center justify-center">
            <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-neutral-900">Censorship resistant</h3>
            <p class="text-sm text-neutral-600 mt-1">No single entity controls the network. Fast, decentralized blockchains process thousands of TPS.</p>
          </div>
        </div>
      </div>
    </Container>
  </div>

  <!-- Supported By -->
  <div class="py-12 bg-gradient-to-bl from-primary-900 to-primary-700">
    <Container>
      <p class="text-center text-xs text-neutral-400 uppercase tracking-wider mb-6">Supported by</p>
      <div class="flex flex-wrap gap-8 md:gap-12 items-center justify-center">
        <span class="text-sm font-medium text-neutral-300">Gitcoin Grants</span>
        <span class="text-sm font-medium text-neutral-300">Celo Foundation</span>
        <span class="text-sm font-medium text-neutral-300">Panmoni</span>
      </div>
    </Container>
  </div>

  <!-- Built for the Global South -->
  <div class="py-16 bg-neutral-100">
    <Container>
      <div class="max-w-2xl mx-auto text-center mb-10">
        <Badge color="primary">FEATURES</Badge>
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-900 tracking-tight mt-4">
          Built for the Global South
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6 max-w-3xl mx-auto">
        <div class="bg-white rounded-xl p-6 text-center shadow-sm">
          <div class="text-2xl mb-2">💰</div>
          <h3 class="font-semibold text-neutral-900">Near-Zero Fees</h3>
          <p class="text-sm text-neutral-600 mt-1">Low protocol fees. Pay only gas and the offer creator's spread.</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center shadow-sm">
          <div class="text-2xl mb-2">🔐</div>
          <h3 class="font-semibold text-neutral-900">Trustless Escrow</h3>
          <p class="text-sm text-neutral-600 mt-1">Sequential smart contract escrow. No trust required between parties.</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center shadow-sm">
          <div class="text-2xl mb-2">🌍</div>
          <h3 class="font-semibold text-neutral-900">Combo Remittances</h3>
          <p class="text-sm text-neutral-600 mt-1">Buy groceries, medicine, essentials for recipients. Home delivery included.</p>
        </div>
      </div>
    </Container>
  </div>

  <!-- TradFi vs YapBay -->
  <div class="py-16 bg-gradient-to-bl from-primary-900 to-primary-700 text-white">
    <Container>
      <div class="max-w-2xl mx-auto text-center mb-10">
        <Badge color="secondary">THE DIFFERENCE</Badge>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight mt-4 [text-wrap:balance]">
          Built to fix what's broken
        </h2>
      </div>
      <div class="max-w-3xl mx-auto overflow-hidden rounded-xl border border-neutral-700">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-neutral-700">
              <th class="py-4 px-6 text-sm font-medium text-neutral-400">Feature</th>
              <th class="py-4 px-6 text-sm font-medium text-neutral-400 text-center">Traditional Remittances</th>
              <th class="py-4 px-6 text-sm font-medium text-primary-400 text-center">YapBay</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-700">
            <tr>
              <td class="py-4 px-6 text-sm text-neutral-300">Average cost</td>
              <td class="py-4 px-6 text-sm text-neutral-200 text-center">6.36%</td>
              <td class="py-4 px-6 text-sm text-primary-400 font-semibold text-center">Near zero</td>
            </tr>
            <tr class="bg-neutral-800/50">
              <td class="py-4 px-6 text-sm text-neutral-300">KYC required</td>
              <td class="py-4 px-6 text-sm text-neutral-200 text-center">Yes</td>
              <td class="py-4 px-6 text-sm text-primary-400 font-semibold text-center">No</td>
            </tr>
            <tr>
              <td class="py-4 px-6 text-sm text-neutral-300">Custody</td>
              <td class="py-4 px-6 text-sm text-neutral-200 text-center">Middleman controls your funds</td>
              <td class="py-4 px-6 text-sm text-primary-400 font-semibold text-center">Smart contract escrow</td>
            </tr>
            <tr class="bg-neutral-800/50">
              <td class="py-4 px-6 text-sm text-neutral-300">Access</td>
              <td class="py-4 px-6 text-sm text-neutral-200 text-center">Business hours only</td>
              <td class="py-4 px-6 text-sm text-primary-400 font-semibold text-center">24/7 P2P matching</td>
            </tr>
            <tr>
              <td class="py-4 px-6 text-sm text-neutral-300">Speed</td>
              <td class="py-4 px-6 text-sm text-neutral-200 text-center">Days</td>
              <td class="py-4 px-6 text-sm text-primary-400 font-semibold text-center">Minutes</td>
            </tr>
          </tbody>
        </table>
      </div>
    </Container>
  </div>

  <!-- Built by Real People -->
  <div class="py-16">
    <Container>
      <div class="max-w-xl mx-auto text-center mb-10">
        <Badge color="primary">THE TEAM</Badge>
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-900 tracking-tight mt-4">
          Built by Real People
        </h2>
        <p class="text-neutral-600 mt-2 text-sm">Years of fieldwork. Thousands of people onboarded. One mission.</p>
      </div>

      <div class="flex flex-col md:flex-row gap-10 justify-center items-center">
        <div class="text-center">
          <img src="https://static.georgedonnelly.com/georgedonnelly.jpg" alt="George Donnelly" class="w-28 h-28 rounded-full object-cover mx-auto" loading="lazy" />
          <p class="font-medium text-neutral-900 mt-3">George Donnelly</p>
          <p class="text-xs text-neutral-500">CTO & Founder</p>
          <p class="text-lg mt-1">🇺🇸 🇨🇴</p>
        </div>
        <div class="text-center">
          <img src="https://static.panmoni.com/yb/easytrend.jpg" alt="Easytrend" class="w-28 h-28 rounded-full object-cover mx-auto" loading="lazy" />
          <p class="font-medium text-neutral-900 mt-3">Easytrend</p>
          <p class="text-xs text-neutral-500">Community & Co-Founder</p>
          <p class="text-lg mt-1">🇳🇬</p>
        </div>
        <div class="text-center">
          <img src="https://static.panmoni.com/yb/mystery.png" alt="Jorge Gallo" class="w-28 h-28 rounded-full object-cover mx-auto" loading="lazy" />
          <p class="font-medium text-neutral-900 mt-3">Jorge Gallo</p>
          <p class="text-xs text-neutral-500">COO & Co-Founder</p>
          <p class="text-lg mt-1">🇨🇴 🇨🇦</p>
        </div>
      </div>
    </Container>
  </div>

  <!-- Be Part of It CTA -->
  <div class="bg-gradient-to-bl from-primary-900 to-primary-700 p-8 md:px-20 md:py-20 flex flex-col items-center text-center">
    <h2 class="text-white text-4xl md:text-6xl tracking-tight">
      Be Part of It
    </h2>
    <p class="text-white/70 mt-4 text-lg md:text-xl max-w-xl">
      We're building in public. Join the community, contribute code, or just send money home cheaper than ever before.
    </p>
    <div class="flex mt-5 gap-4 flex-col sm:flex-row">
      <Link href="https://t.me/Panmoni/288" style="inverted" target="_blank" rel="noopener">Join the Telegram Community</Link>
      <Link href="https://github.com/Panmoni/yapbay" style="inverted" target="_blank" rel="noopener">Contribute on GitHub</Link>
    </div>
  </div>
</Layout>
