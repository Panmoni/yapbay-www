---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Badge from "@components/ui/badge.astro";
import Link from "@components/ui/link.astro";
import { Picture } from "astro:assets";
import heroImage from "@assets/hero-screenshot.png";
---

<!-- Option 2: Empowerment/Mission-Focused Landing Page -->
<!-- Focus: Bold vision, values, and mission - emotional, aspirational -->

<Layout footerMargin={false}>
  <!-- Vision Hero -->
  <div class="overflow-x-clip">
    <Container>
      <main class="grid lg:grid-cols-5 place-items-center relative mt-8">
        <div class="absolute w-96 h-96 blur-2xl -z-10 bg-gradient-radial from-primary-500 right-0 top-0"></div>
        <div class="absolute w-96 h-96 blur-2xl -z-10 bg-gradient-radial from-secondary-300 right-56 top-10"></div>

        <div class="max-w-sm md:max-w-max lg:col-span-2">
          <Badge color="secondary">WEB3 P2P REMITTANCES</Badge>
          <h1 class="text-3xl lg:text-4xl xl:text-6xl font-bold lg:tracking-tight xl:tracking-tighter [text-wrap:balance] text-center lg:text-start mt-4">
            Monetary Freedom<br class="hidden md:block" /> for Every Human
          </h1>
          <p class="text-lg mt-4 max-w-lg text-neutral-600 [text-wrap:balance] text-center lg:text-start">
            A world where everyone can use and create money as they see fit, participate in the global economy on their own terms -- no KYC, no limits, no middlemen.
          </p>
          <div class="mt-6 flex flex-col sm:flex-row sm:justify-center lg:justify-start gap-3">
            <Link size="lg" style="primary" href="https://t.me/Panmoni/288" target="_blank" rel="noopener">Start Sending</Link>
            <Link size="lg" style="outline" rel="noopener" href="https://yapbay.com/about/" target="_blank">Learn More</Link>
          </div>
        </div>
        <div class="py-3 lg:col-span-3 lg:-mr-44">
          <Picture
            src={heroImage}
            alt="Remittances"
            formats={["avif", "webp"]}
            sizes="(max-width: 1024px) 100vw, 50vw"
            widths={[240, 540, 720, heroImage.width]}
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </main>
    </Container>
  </div>

  <!-- Values -->
  <div class="py-20 bg-neutral-900 text-white">
    <Container>
      <div class="text-center mb-12">
        <Badge color="secondary">OUR VALUES</Badge>
        <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight mt-4">
          What We Stand For
        </h2>
      </div>
      <div class="grid md:grid-cols-5 gap-6">
        <div class="bg-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl mb-3">🌍</div>
          <h3 class="font-bold text-lg">Financial Inclusion</h3>
          <p class="text-neutral-400 text-sm mt-2">Banking the unbanked -- 2 billion people deserve access to global finance.</p>
        </div>
        <div class="bg-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl mb-3">💸</div>
          <h3 class="font-bold text-lg">Affordable Remittances</h3>
          <p class="text-neutral-400 text-sm mt-2">High fees on small transfers are a tax on the poor. We end that.</p>
        </div>
        <div class="bg-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl mb-3">🛡️</div>
          <h3 class="font-bold text-lg">Censorship Resistance</h3>
          <p class="text-neutral-400 text-sm mt-2">No one should be able to block your access to your own money.</p>
        </div>
        <div class="bg-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl mb-3">🔄</div>
          <h3 class="font-bold text-lg">Crisis Resilience</h3>
          <p class="text-neutral-400 text-sm mt-2">When TradFi fails, P2P networks keep flowing.</p>
        </div>
        <div class="bg-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl mb-3">⚡</div>
          <h3 class="font-bold text-lg">Economic Empowerment</h3>
          <p class="text-neutral-400 text-sm mt-2">Every human should be able to participate in the global economy.</p>
        </div>
      </div>
    </Container>
  </div>

  <!-- Tech on Solana -->
  <div class="py-20">
    <Container>
      <div class="max-w-3xl mx-auto text-center">
        <Badge color="primary">THE TECHNOLOGY</Badge>
        <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight mt-4">
          Built on Solana
        </h2>
        <p class="text-lg text-neutral-600 mt-4 [text-wrap:pretty]">
          Fast, cheap, and energy-efficient -- Solana processes thousands of transactions per second for fractions of a cent. The perfect backbone for P2P remittances.
        </p>
      </div>
    </Container>
  </div>

  <!-- Community Backers -->
  <div class="py-12 border-t border-b border-neutral-200">
    <Container>
      <p class="text-center text-neutral-500 mb-6 text-sm uppercase tracking-wider font-medium">Backed By</p>
      <div class="flex flex-wrap gap-x-12 gap-y-6 items-center justify-center">
        <div class="text-neutral-500 font-semibold">Solana Eternal Hackathon</div>
        <div class="text-neutral-500 font-semibold">Gitcoin Grants 20</div>
        <div class="text-neutral-500 font-semibold">Celo Proof of Ship</div>
        <div class="text-neutral-500 font-semibold">Backdrop Build Hackathon</div>
        <div class="text-neutral-500 font-semibold">BCH Community</div>
        <div class="text-neutral-500 font-semibold">Dash DAO</div>
      </div>
    </Container>
  </div>

  <!-- Feature Grid -->
  <div class="py-20">
    <Container>
      <div class="max-w-3xl mx-auto text-center">
        <Badge color="primary">THE PROTOCOL</Badge>
        <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight mt-4">
          How YapBay Works
        </h2>
        <p class="text-lg text-neutral-600 mt-4 [text-wrap:pretty]">
          Chain two P2P trade offers into one fiat-in, fiat-out transaction. USDC as the transport layer means recipients get local fiat -- no crypto knowledge required.
        </p>
      </div>

      <div class="grid md:grid-cols-2 py-10 gap-16 mt-8">
        <div class="grid place-items-center">
          <div class="max-w-lg">
            <Badge color="primary" class="-ml-px">Trustless Escrow</Badge>
            <h3 class="text-2xl font-medium mt-4 [text-wrap:balance]">
              Smart Contract Security
            </h3>
            <p class="mt-4 text-neutral-600 [text-wrap:balance]">
              Sequential escrow built on Solana ensures every step of your transaction is secure. No trust between parties needed -- the code enforces the rules.
            </p>
            <ul class="grid mt-6 text-left gap-y-4">
              <li class="flex items-center gap-3 text-neutral-800">
                <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6.2 4.2a1 1 0 11-1.4 1.4 1 1 0 011.4-1.4z" />
                </svg>
                <span class="text-sm">Dispute resolution via evidence and arbitration</span>
              </li>
              <li class="flex items-center gap-3 text-neutral-800">
                <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6.2 4.2a1 1 0 11-1.4 1.4 1 1 0 011.4-1.4z" />
                </svg>
                <span class="text-sm">5% security deposit forfeited by bad actor</span>
              </li>
              <li class="flex items-center gap-3 text-neutral-800">
                <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6.2 4.2a1 1 0 11-1.4 1.4 1 1 0 011.4-1.4z" />
                </svg>
                <span class="text-sm">100% on-chain transparency</span>
              </li>
            </ul>
          </div>
        </div>
        <div class="grid place-items-center">
          <div class="max-w-lg">
            <Badge color="secondary" class="-ml-px">Combo Remittances</Badge>
            <h3 class="text-2xl font-medium mt-4 [text-wrap:balance]">
              More Than Just Money
            </h3>
            <p class="mt-4 text-neutral-600 [text-wrap:balance]">
              Recipients in underserved areas often lack access to basic goods. Combo remittances let senders buy groceries, medicine, and essentials -- delivered locally.
            </p>
            <ul class="grid mt-6 text-left gap-y-4">
              <li class="flex items-center gap-3 text-neutral-800">
                <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6.2 4.2a1 1 0 11-1.4 1.4 1 1 0 011.4-1.4z" />
                </svg>
                <span class="text-sm">Local merchant network</span>
              </li>
              <li class="flex items-center gap-3 text-neutral-800">
                <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6.2 4.2a1 1 0 11-1.4 1.4 1 1 0 011.4-1.4z" />
                </svg>
                <span class="text-sm">Home delivery included</span>
              </li>
              <li class="flex items-center gap-3 text-neutral-800">
                <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6.2 4.2a1 1 0 11-1.4 1.4 1 1 0 011.4-1.4z" />
                </svg>
                <span class="text-sm">Pay in local fiat on receipt</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </Container>
  </div>

  <!-- Team -->
  <div class="bg-neutral-100 py-16">
    <Container>
      <div class="max-w-3xl mx-auto text-center">
        <Badge color="primary">THE TEAM</Badge>
        <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight mt-4">
          Built by Real People
        </h2>
        <p class="text-lg text-neutral-600 mt-4 [text-wrap:pretty]">
          We've spent years in the field -- onboarding people to crypto, running remittances pilots, and learning what works.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-8 mt-12 max-w-3xl mx-auto">
        <div class="bg-white rounded-xl p-6 text-center shadow-sm">
          <div class="w-16 h-16 rounded-full bg-primary-100 mx-auto flex items-center justify-center text-2xl font-bold text-primary-600">GD</div>
          <h3 class="font-bold text-lg mt-4">George Donnelly</h3>
          <p class="text-primary-600 text-sm">CTO -- Founder</p>
          <p class="text-neutral-500 text-sm mt-2">Builder. Bitcoin since 2013. Solidity + Rust.</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center shadow-sm">
          <div class="w-16 h-16 rounded-full bg-secondary-300 mx-auto flex items-center justify-center text-2xl font-bold text-secondary-600">ET</div>
          <h3 class="font-bold text-lg mt-4">Easytrend</h3>
          <p class="text-secondary-600 text-sm">Community -- Co-Founder</p>
          <p class="text-neutral-500 text-sm mt-2">Latin America fieldwork lead. Onboarded ~10,000 people.</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center shadow-sm">
          <div class="w-16 h-16 rounded-full bg-primary-100 mx-auto flex items-center justify-center text-2xl font-bold text-primary-600">JG</div>
          <h3 class="font-bold text-lg mt-4">Jorge Gallo</h3>
          <p class="text-primary-600 text-sm">COO -- Co-Founder</p>
          <p class="text-neutral-500 text-sm mt-2">Operations. Madrid-Caracas pilot. Logistics expert.</p>
        </div>
      </div>
    </Container>
  </div>

  <!-- CTA -->
  <div class="bg-gradient-to-bl from-primary-900 to-primary-700 p-8 md:px-20 md:py-20 flex flex-col items-center text-center">
    <h2 class="text-white text-4xl md:text-6xl tracking-tight">
      Be Part of It
    </h2>
    <p class="text-white/70 mt-4 text-lg md:text-xl max-w-xl">
      We're building in public. Join the community, contribute code, or just send money home cheaper than ever before.
    </p>
    <div class="flex mt-5 gap-4 flex-col sm:flex-row">
      <Link href="https://t.me/Panmoni/288" style="inverted" target="_blank" rel="noopener">Join the Telegram Community</Link>
      <Link href="https://github.com/Panmoni/yapbay" style="outline" target="_blank" rel="noopener">Contribute on GitHub</Link>
    </div>
  </div>
</Layout>
