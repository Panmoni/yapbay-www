---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Badge from "@components/ui/badge.astro";
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";

const team = [
  {
    name: "George Donnelly",
    role: "CTO & Founder",
    location: "🇺🇸 🇨🇴",
    image: "https://static.georgedonnelly.com/georgedonnelly.jpg",
    links: { github: "https://github.com/georgedonnelly", twitter: "https://x.com/georgedonnelly_" },
    bio: "Bitcoin since 2011. Taught thousands of people across Latam the basics of Bitcoin. Dev with experience in P2P and regulated fintech. 2x Honorable Mention @ Colosseum hackathons.",
  },
  {
    name: "Easytrend",
    role: "Community & Co-Founder",
    location: "🇳🇬",
    image: "https://static.panmoni.com/yb/easytrend.jpg",
    links: { github: "", twitter: "" },
    bio: "Solana Superteam Nigeria community leader.",
  },
  {
    name: "Jorge Gallo",
    role: "COO & Co-Founder",
    location: "🇨🇴 🇨🇦",
    image: "https://static.panmoni.com/yb/mystery.png",
    links: { github: "", twitter: "" },
    bio: "On-chain data wizard.",
  },
];

const projects = [
  {
    name: "LocalSolana (2021-2022)",
    description: "A proof-of-concept P2P trading interface on Solana. Showed that non-crypto-native users could navigate a trading interface if the UX was simple enough.",
  },
  {
    name: "YapBay on Celo (2024-2025)",
    description: "Built YapBay MVP on Celo with Solidity contracts. Deployed to Alfajores testnet and then Celo mainnet with a 100 USDC trade limit to test with real money. Learned a lot about what breaks in production.",
  },
  {
    name: "YapBay V3 (current)",
    description: "Multi-chain from the start. Better UX, trust features, and designed for real corridors. All contracts and frontend are MIT licensed on GitHub.",
  },
];
---

<Layout title="About" footerMargin={false}>
  <!-- Header -->
  <div class="py-16 md:py-24">
    <Container>
      <div class="max-w-3xl mx-auto">
        <div class="flex items-center justify-between">
          <div>
            <Badge color="secondary">ABOUT</Badge>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-neutral-900 tracking-tight mt-4">
              We started Panmoni to make money work across borders
            </h1>
          </div>
          <img src="/panmoni.svg" alt="Panmoni" class="h-20 md:h-28 ml-8 shrink-0" />
        </div>
        <p class="text-lg text-neutral-600 mt-6 max-w-xl">
          YapBay is our remittances protocol. Built after years of fieldwork, one successful pilot, and a lot of learning. No VC funding. No empty promises. Just code and community.
        </p>
      </div>
    </Container>
  </div>

  <!-- The origin story -->
  <div class="py-16 border-t border-neutral-200">
    <Container>
      <div class="max-w-3xl mx-auto">
        <div class="grid md:grid-cols-5 gap-10">
          <div class="md:col-span-2">
            <h2 class="text-2xl font-bold text-neutral-900 mb-4">The origin story</h2>
            <p class="text-neutral-600 leading-relaxed">
              It started in 2018 in Latin America. We were teaching people to use simple crypto wallets. Most weren't interested in speculation — they just wanted to send money home.
            </p>
          </div>
          <div class="md:col-span-3 space-y-4 text-neutral-600 leading-relaxed">
            <p>
              The existing options were expensive, slow, and unreliable. Banks charged too much. Western Union was worse. Even crypto on-ramps were confusing and unreliable. Meanwhile, almost everyone had a phone.
            </p>
            <p>
              In 2019 we ran a remittances pilot between Madrid and Caracas. Venezuelan immigrants in Spain wanted to send money home for food. We invented combo remittances — their funds paid for groceries directly, cross-border with Dash, through a network of local stores. It worked — real people used it, real money moved.
            </p>
            <p>
              But it was fragile. It depended on trust, on specific people being available, on manual coordination. When the pandemic hit, the logistics collapsed. The lesson was clear: you can't build durable financial infrastructure on goodwill alone.
            </p>
            <p>
              So we built YapBay. The workflow, the trust problems, the edge cases — all of it translated into code. Smart contracts hold funds. P2P matching replaces manual coordination. No middleman.
            </p>
          </div>
        </div>
      </div>
    </Container>
  </div>

  <!-- Problem & Solution — The Stats -->
  <div class="py-16 bg-gradient-to-bl from-primary-900 to-primary-700 text-white">
    <Container>
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <p class="text-primary-300 uppercase tracking-wider text-sm font-medium mb-3">The problem is massive</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">Remittances are broken</h2>
          <p class="text-neutral-300 max-w-2xl mx-auto text-lg">
            Sub-$200 remittances face the highest fees, disproportionately hurting families that need every dollar most.
          </p>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white/5 backdrop-blur rounded-2xl p-8 text-center border border-white/10">
            <div class="text-5xl font-bold text-primary-400 mb-4">6.36%</div>
            <p class="text-white font-medium mb-2">Global average cost</p>
            <p class="text-neutral-400 text-sm">To send $200 globally (World Bank RPW, Q3 2025). More than double the 3% SDG target.</p>
          </div>
          <div class="bg-white/5 backdrop-blur rounded-2xl p-8 text-center border border-white/10">
            <div class="text-5xl font-bold text-primary-400 mb-4">8.78%</div>
            <p class="text-white font-medium mb-2">Sub-Saharan Africa</p>
            <p class="text-neutral-400 text-sm">The world's most expensive region (World Bank, Q1 2025).</p>
          </div>
          <div class="bg-white/5 backdrop-blur rounded-2xl p-8 text-center border border-white/10">
            <div class="text-5xl font-bold text-primary-400 mb-4">800M+</div>
            <p class="text-white font-medium mb-2">People locked out</p>
            <p class="text-neutral-400 text-sm">Without official ID, excluded from formal finance. Another 2.8B lack digital ID.</p>
          </div>
        </div>
      </div>
    </Container>
  </div>

  <!-- Problem vs Solution -->
  <div class="py-16 border-t border-neutral-200">
    <Container>
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-2xl font-bold text-neutral-900">The hidden cost of every transfer</h2>
          <p class="text-neutral-500 mt-2 max-w-lg mx-auto">Traditional remittances vs YapBay</p>
        </div>
        <div class="space-y-6">
          <!-- Fees -->
          <div class="bg-white rounded-2xl border border-neutral-200 overflow-hidden">
            <div class="flex flex-col md:flex-row">
              <div class="md:w-1/2 p-6 bg-red-50 border-b md:border-b-0 md:border-r border-red-100">
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center shrink-0">
                    <span class="text-xl">💸</span>
                  </div>
                  <div>
                    <p class="text-red-600 text-xs font-medium uppercase tracking-wider mb-1">Traditional</p>
                    <h3 class="font-semibold text-neutral-900">Fees stack on fees</h3>
                    <p class="text-neutral-600 text-sm mt-2">Fixed transfer fees plus exchange rate markups. The "zero fee" ads hide the spread.</p>
                  </div>
                </div>
              </div>
              <div class="md:w-1/2 p-6 bg-green-50">
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center shrink-0">
                    <span class="text-xl">⚡</span>
                  </div>
                  <div>
                    <p class="text-green-600 text-xs font-medium uppercase tracking-wider mb-1">YapBay</p>
                    <h3 class="font-semibold text-neutral-900">Near-zero fees</h3>
                    <p class="text-neutral-600 text-sm mt-2">No YapBay fees (for now). You pay gas + the trader's spread. That's it.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- ID -->
          <div class="bg-white rounded-2xl border border-neutral-200 overflow-hidden">
            <div class="flex flex-col md:flex-row">
              <div class="md:w-1/2 p-6 bg-red-50 border-b md:border-b-0 md:border-r border-red-100">
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center shrink-0">
                    <span class="text-xl">🪪</span>
                  </div>
                  <div>
                    <p class="text-red-600 text-xs font-medium uppercase tracking-wider mb-1">Traditional</p>
                    <h3 class="font-semibold text-neutral-900">ID requirements lock people out</h3>
                    <p class="text-neutral-600 text-sm mt-2">800 million people lack formal ID. Even for those who have it, KYC is slow and intrusive.</p>
                  </div>
                </div>
              </div>
              <div class="md:w-1/2 p-6 bg-green-50">
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center shrink-0">
                    <span class="text-xl">📱</span>
                  </div>
                  <div>
                    <p class="text-green-600 text-xs font-medium uppercase tracking-wider mb-1">YapBay</p>
                    <h3 class="font-semibold text-neutral-900">Just a wallet</h3>
                    <p class="text-neutral-600 text-sm mt-2">No KYC at the protocol level. No identity data stored — nothing to leak.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- Speed -->
          <div class="bg-white rounded-2xl border border-neutral-200 overflow-hidden">
            <div class="flex flex-col md:flex-row">
              <div class="md:w-1/2 p-6 bg-red-50 border-b md:border-b-0 md:border-r border-red-100">
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center shrink-0">
                    <span class="text-xl">⏰</span>
                  </div>
                  <div>
                    <p class="text-red-600 text-xs font-medium uppercase tracking-wider mb-1">Traditional</p>
                    <h3 class="font-semibold text-neutral-900">Speed is unreliable</h3>
                    <p class="text-neutral-600 text-sm mt-2">Days for a wire. Business hours only. Holidays off. Power outages freeze transfers.</p>
                  </div>
                </div>
              </div>
              <div class="md:w-1/2 p-6 bg-green-50">
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center shrink-0">
                    <span class="text-xl">🌍</span>
                  </div>
                  <div>
                    <p class="text-green-600 text-xs font-medium uppercase tracking-wider mb-1">YapBay</p>
                    <h3 class="font-semibold text-neutral-900">Works in crisis</h3>
                    <p class="text-neutral-600 text-sm mt-2">P2P networks don't go down when banks do. As long as your phone works.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- Frozen -->
          <div class="bg-white rounded-2xl border border-neutral-200 overflow-hidden">
            <div class="flex flex-col md:flex-row">
              <div class="md:w-1/2 p-6 bg-red-50 border-b md:border-b-0 md:border-r border-red-100">
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center shrink-0">
                    <span class="text-xl">🛡️</span>
                  </div>
                  <div>
                    <p class="text-red-600 text-xs font-medium uppercase tracking-wider mb-1">Traditional</p>
                    <h3 class="font-semibold text-neutral-900">Your account can be frozen</h3>
                    <p class="text-neutral-600 text-sm mt-2">Banks can freeze funds, reverse transactions, or block transfers anytime.</p>
                  </div>
                </div>
              </div>
              <div class="md:w-1/2 p-6 bg-green-50">
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center shrink-0">
                    <span class="text-xl">🔐</span>
                  </div>
                  <div>
                    <p class="text-green-600 text-xs font-medium uppercase tracking-wider mb-1">YapBay</p>
                    <h3 class="font-semibold text-neutral-900">Smart contract escrow</h3>
                    <p class="text-neutral-600 text-sm mt-2">Funds locked until both confirm. No middleman can freeze or reverse.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- Combo -->
          <div class="bg-white rounded-2xl border border-neutral-200 overflow-hidden">
            <div class="flex flex-col md:flex-row">
              <div class="md:w-1/2 p-6 bg-neutral-50 border-b md:border-b-0 md:border-r border-neutral-200">
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-neutral-200 rounded-full flex items-center justify-center shrink-0">
                    <span class="text-xl">💸</span>
                  </div>
                  <div>
                    <p class="text-neutral-500 text-xs font-medium uppercase tracking-wider mb-1">Bonus</p>
                    <h3 class="font-semibold text-neutral-900">Combo remittances</h3>
                    <p class="text-neutral-600 text-sm mt-2">Send money AND buy groceries, medicine, or essentials for your recipient.</p>
                  </div>
                </div>
              </div>
              <div class="md:w-1/2 p-6 bg-green-50">
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center shrink-0">
                    <span class="text-xl">🛒</span>
                  </div>
                  <div>
                    <p class="text-green-600 text-xs font-medium uppercase tracking-wider mb-1">YapBay</p>
                    <h3 class="font-semibold text-neutral-900">One transaction</h3>
                    <p class="text-neutral-600 text-sm mt-2">All delivered locally. All in one transaction.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </div>

  <!-- How YapBay works technically -->
  <div class="py-20 bg-gradient-to-bl from-primary-900 to-primary-700 text-white">
    <Container>
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <p class="text-primary-300 uppercase tracking-wider text-sm font-medium mb-3">How it works</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">Sequential P2P escrow</h2>
          <p class="text-neutral-300 max-w-2xl mx-auto text-lg">
            YapBay chains two P2P trades into one fiat-in, fiat-out transaction. No middleman. No custody. Just smart contracts doing the work.
          </p>
        </div>

        <!-- Flow visualization -->
        <div class="bg-white/5 backdrop-blur rounded-2xl p-8 mb-10 border border-white/10">
          <div class="flex flex-col md:flex-row items-center justify-between gap-4">
            <div class="text-center">
              <div class="w-14 h-14 bg-primary-500 rounded-full flex items-center justify-center mx-auto mb-3">
                <span class="text-xl">📱</span>
              </div>
              <p class="text-sm font-medium">Pick offer 1</p>
              <p class="text-xs text-neutral-400">Buy crypto with fiat</p>
            </div>
            <div class="hidden md:block text-primary-400 text-xl">→</div>
            <div class="hidden md:block text-neutral-600">—</div>
            <div class="text-center">
              <div class="w-14 h-14 bg-primary-500 rounded-full flex items-center justify-center mx-auto mb-3">
                <span class="text-xl">💵</span>
              </div>
              <p class="text-sm font-medium">Pay fiat</p>
              <p class="text-xs text-neutral-400">Get stablecoin</p>
            </div>
            <div class="hidden md:block text-neutral-600">—</div>
            <div class="text-center">
              <div class="w-20 h-20 bg-primary-400 rounded-full flex items-center justify-center mx-auto mb-3 shadow-lg shadow-primary-400/30">
                <span class="text-3xl">🔐</span>
              </div>
              <p class="text-base font-bold text-white">Sequential escrow</p>
              <p class="text-xs text-neutral-400 mt-1">Auto-transfers between legs</p>
            </div>
            <div class="hidden md:block text-neutral-600">—</div>
            <div class="text-center">
              <div class="w-14 h-14 bg-primary-500 rounded-full flex items-center justify-center mx-auto mb-3">
                <span class="text-xl">📱</span>
              </div>
              <p class="text-sm font-medium">Pick offer 2</p>
              <p class="text-xs text-neutral-400">Sell crypto for local fiat</p>
            </div>
            <div class="hidden md:block text-primary-400 text-xl">→</div>
            <div class="hidden md:block text-neutral-600">—</div>
            <div class="text-center">
              <div class="w-14 h-14 bg-green-500 rounded-full flex items-center justify-center mx-auto mb-3">
                <span class="text-xl">🤝</span>
              </div>
              <p class="text-sm font-medium leading-tight">Recipient gets</p>
              <p class="text-sm font-medium leading-tight">local fiat</p>
            </div>
          </div>
        </div>

        <!-- Legs explanation -->
        <div class="grid md:grid-cols-2 gap-6 mb-10">
          <div class="bg-white/5 backdrop-blur rounded-xl p-6 border border-white/10">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 bg-primary-500 rounded-full flex items-center justify-center text-sm font-bold">1</div>
              <h3 class="font-bold text-lg">Leg 1</h3>
            </div>
            <p class="text-neutral-300 text-sm leading-relaxed">
              You find an offer. You pay fiat (e.g., USD) to a trader — they give you stablecoin (e.g., USDC). That stablecoin goes into the smart contract escrow. The escrow holds the funds.
            </p>
          </div>
          <div class="bg-white/5 backdrop-blur rounded-xl p-6 border border-white/10">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 bg-primary-500 rounded-full flex items-center justify-center text-sm font-bold">2</div>
              <h3 class="font-bold text-lg">Leg 2</h3>
            </div>
            <p class="text-neutral-300 text-sm leading-relaxed">
              Your stablecoin is automatically escrowed into Leg 2. Another trader buys your stablecoin and delivers local fiat to your recipient. The escrow transfers automatically — no extra steps.
            </p>
          </div>
        </div>

        <p class="text-center text-neutral-400 text-sm mb-10">
          Neither sender nor receiver need touch crypto if they don't feel comfortable with it. Traders handle the local fiat side. You just pick your offers, pay in fiat, and recipients get cash deposited.
        </p>

        <!-- Key features -->
        <div class="grid md:grid-cols-4 gap-4">
          <div class="bg-white/5 backdrop-blur rounded-xl p-5 text-center border border-white/10">
            <div class="text-3xl mb-3">🔐</div>
            <h3 class="font-bold text-sm mb-2">Smart contract</h3>
            <p class="text-neutral-400 text-xs">Funds locked until both parties confirm. No one can freeze them.</p>
          </div>
          <div class="bg-white/5 backdrop-blur rounded-xl p-5 text-center border border-white/10">
            <div class="text-3xl mb-3">🌍</div>
            <h3 class="font-bold text-sm mb-2">Traders</h3>
            <p class="text-neutral-400 text-xs">Independent operators set their own rates in specific corridors.</p>
          </div>
          <div class="bg-white/5 backdrop-blur rounded-xl p-5 text-center border border-white/10">
            <div class="text-3xl mb-3">⚖️</div>
            <h3 class="font-bold text-sm mb-2">Disputes</h3>
            <p class="text-neutral-400 text-xs">5% security bond from both parties. Community governance decides.</p>
          </div>
          <div class="bg-white/5 backdrop-blur rounded-xl p-5 text-center border border-white/10">
            <div class="text-3xl mb-3">📱</div>
            <h3 class="font-bold text-sm mb-2">No KYC</h3>
            <p class="text-neutral-400 text-xs">The protocol only needs a wallet — no phone number required. Traders choose their own rules.</p>
          </div>
        </div>
      </div>
    </Container>
  </div>

  <!-- Team -->
  <div class="py-16 border-t border-neutral-200">
    <Container>
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-neutral-900 mb-8">The team</h2>
        <div class="space-y-10">
          {team.map((member) => (
            <div class="flex gap-6 items-start">
              <img
                src={member.image}
                alt={member.name}
                class="w-20 h-20 rounded-full object-cover shrink-0"
                loading="lazy"
              />
              <div>
                <div class="flex items-center gap-3">
                  <h3 class="font-bold text-lg text-neutral-900">{member.name}</h3>
                  <span class="text-lg">{member.location}</span>
                </div>
                <p class="text-sm text-primary-600 font-medium mt-0.5">{member.role}</p>
                <p class="text-neutral-600 mt-2 leading-relaxed">{member.bio}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </div>

  <!-- Open source -->
  <div class="py-16 bg-gradient-to-bl from-primary-900 to-primary-700 text-white">
    <Container>
      <div class="max-w-3xl mx-auto text-center">
        <div class="text-4xl mb-4">🔗</div>
        <h2 class="text-2xl font-bold mb-4">Everything is open source</h2>
        <p class="text-neutral-400 max-w-lg mx-auto leading-relaxed">
          All YapBay code is MIT licensed. The contracts, the API, the frontend — all public. You can read it, audit it, fork it, build on it.
        </p>
        <div class="flex flex-wrap gap-4 justify-center mt-8">
          <a href="https://github.com/Panmoni/yapbay" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-neutral-300 hover:text-white transition">
            <Icon name="bx:bxl-github" class="w-5 h-5" />
            yapbay
          </a>
          <a href="https://github.com/Panmoni/yapbay-api" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-neutral-300 hover:text-white transition">
            <Icon name="bx:bxl-github" class="w-5 h-5" />
            yapbay-api
          </a>
          <a href="https://github.com/Panmoni/pricing" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-neutral-300 hover:text-white transition">
            <Icon name="bx:bxl-github" class="w-5 h-5" />
            pricing
          </a>
          <a href="https://github.com/Panmoni/yapbay-contracts-solidity" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-neutral-300 hover:text-white transition">
            <Icon name="bx:bxl-github" class="w-5 h-5" />
            yapbay-contracts-solidity
          </a>
          <a href="https://github.com/Panmoni/yapbay-solana-anchor" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-neutral-300 hover:text-white transition">
            <Icon name="bx:bxl-github" class="w-5 h-5" />
            yapbay-solana-anchor
          </a>
        </div>
      </div>
    </Container>
  </div>

  <!-- Contact CTA -->
  <div class="py-16">
    <Container>
      <div class="max-w-xl mx-auto text-center">
        <h2 class="text-2xl font-bold text-neutral-900 mb-4">Questions, ideas, or just want to talk?</h2>
        <p class="text-neutral-600 mb-6">
          We're building in public. Join the Telegram community or reach out directly.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Link size="lg" style="primary" href="https://t.me/Panmoni/288" target="_blank" rel="noopener">
            Join Telegram
          </Link>
          <Link size="lg" style="outline" href="/contact">
            Get in Touch
          </Link>
